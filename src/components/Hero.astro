---
<section class="hero" id="overview">
    <div class="hero-container">
        <div class="hero-background" id="hero-background"></div>
        <div class="hero-content">
            <div class="hero-main">
                <h1 class="hero-title">
                    Pioneering 
                    <span class="accent-highlight">Intelligent Biology</span>
                </h1>
                <p class="hero-description">
                    We unite metabolic engineering, synthetic biology, and artificial intelligence to develop sustainable biotechnological solutions for medicine, industry, and the environment. Our research focuses on creating computational models that accelerate discovery and optimize biological systems.
                </p>
                <div class="hero-actions">
                    <a href={`${import.meta.env.BASE_URL}/#contact`} class="hero-button primary">Collaborate With Us</a>
                    <a href={`${import.meta.env.BASE_URL}/research`} class="hero-button secondary">Explore Research</a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .hero {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }
</style>
