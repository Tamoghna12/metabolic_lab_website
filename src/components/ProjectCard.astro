---
interface Props {
	project: any;
}

const { project } = Astro.props;
const { data, id } = project;
---

<article class="card-surface project-card reveal">
    <div class="project-content">
        <span class={`project-status ${data.status.toLowerCase().replace(/\s+/g, '-')}`}>{data.status}</span>
        <h3 class="card-title mt-2">{data.title}</h3>
        <p class="card-text mb-4">{data.summary}</p>
        {data.image && <img src={data.image} alt={data.title} class="card-image mb-4" loading="lazy" />}
        <div class="project-actions">
            <a href={`${import.meta.env.BASE_URL}/research#${id}`} class="pill-button secondary small">Learn More</a>
        </div>
    </div>
</article>

<style>
    .project-card {
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease;
    }
    .project-card:hover {
        transform: translateY(-5px);
    }
    .project-status {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        background: var(--color-background-alt);
    }
    .project-status.active { color: #059669; background: #ecfdf5; }
    .project-status.completed { color: #6b7280; background: #f3f4f6; }
</style>
