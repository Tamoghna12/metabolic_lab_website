---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const newsItems = await getCollection('news');
const sortedNews = newsItems.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Group by year
const newsByYear: Record<string, typeof sortedNews> = {};
sortedNews.forEach(item => {
    const year = new Date(item.data.date).getFullYear().toString();
    if (!newsByYear[year]) newsByYear[year] = [];
    newsByYear[year].push(item);
});
---

<BaseLayout title="News" description="Latest updates and announcements from the BioAI Lab.">
    <Header />

    <main class="py-20">
        <div class="max-container">
            <!-- Page Header -->
            <div class="section-header mb-16">
                <span class="section-eyebrow">Updates</span>
                <h1 class="text-5xl font-bold mb-6 tracking-tight">Lab <span class="text-primary">News</span> & Events</h1>
                <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed">Stay up to date with our latest announcements, publications, achievements, and lab activities.</p>
            </div>

            <!-- Timeline -->
            <div class="relative max-w-4xl mx-auto">
                {/* Vertical line */}
                <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-border transform md:-translate-x-1/2"></div>

                {Object.entries(newsByYear).map(([year, items], yearIndex) => (
                    <div class="mb-16 last:mb-0">
                        {/* Year Badge */}
                        <div class="relative flex items-center justify-center mb-10">
                            <span class="bg-primary text-white text-sm font-bold px-6 py-2 rounded-full relative z-10 shadow-md">{year}</span>
                        </div>

                        {/* News Items for this Year */}
                        <div class="space-y-8">
                            {items.map((item, index) => {
                                const date = new Date(item.data.date);
                                const formattedDate = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                                const isLeft = index % 2 === 0;

                                return (
                                    <article class="relative flex flex-col md:flex-row gap-6 md:gap-0 reveal" style={`animation-delay: ${(yearIndex * 200 + index * 100)}ms`}>
                                        {/* Timeline Dot */}
                                        <div class="absolute left-4 md:left-1/2 w-3 h-3 bg-primary rounded-full border-4 border-background transform -translate-x-1/2 z-10 mt-8"></div>

                                        {/* Content Card */}
                                        <div class={`md:w-1/2 ${isLeft ? 'md:pr-12 md:text-right' : 'md:pl-12 md:ml-auto'} pl-12 md:pl-0`}>
                                            <div class="card-surface p-6 group hover:-translate-y-1 transition-all duration-300">
                                                {item.data.image && (
                                                    <div class="mb-4 rounded-xl overflow-hidden">
                                                        <img src={item.data.image} alt={item.data.title} class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500" />
                                                    </div>
                                                )}
                                                <time class="text-xs font-semibold text-primary uppercase tracking-wider">{formattedDate}</time>
                                                <h3 class="text-lg font-bold mt-2 mb-3 group-hover:text-primary transition-colors leading-snug">{item.data.title}</h3>
                                                <p class="text-text-secondary text-sm leading-relaxed">{item.data.summary}</p>
                                                {item.data.authors && (
                                                    <p class="text-text-tertiary text-xs mt-3 italic">By {item.data.authors}</p>
                                                )}
                                            </div>
                                        </div>
                                    </article>
                                );
                            })}
                        </div>
                    </div>
                ))}
            </div>

            <!-- Subscribe CTA -->
            <section class="mt-20 card-surface p-10 text-center bg-gradient-to-br from-primary/5 to-accent/5 border-primary/10">
                <div class="text-4xl mb-4">📬</div>
                <h2 class="text-2xl font-bold mb-3">Stay Updated</h2>
                <p class="text-text-secondary max-w-xl mx-auto mb-6">Want to receive our latest updates? Follow us on social media or reach out to join our mailing list.</p>
                <a href={`${import.meta.env.BASE_URL}/#contact`} class="pill-button">Contact Us</a>
            </section>
        </div>
    </main>

    <Footer />
</BaseLayout>

<style>
    @media (max-width: 768px) {
        .md\\:w-1\/2 {
            width: 100% !important;
        }
        .md\\:pr-12 {
            padding-right: 0 !important;
        }
        .md\\:ml-auto {
            margin-left: 0 !important;
        }
        .md\\:text-right {
            text-align: left !important;
        }
    }
</style>
