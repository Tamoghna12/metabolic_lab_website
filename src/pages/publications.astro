---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PublicationList from '../components/ui/PublicationList.jsx';

const allPublications = await getCollection('publications');
const sortedPublications = allPublications.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Publications" description="Research publications from the BioAI Lab.">
    <Header />
    
    <main class="py-16">
        <div class="max-container">
            <div class="section-header mb-12 text-center">
                <span class="section-eyebrow">Research Output</span>
                <h1 class="text-4xl font-bold mb-4">Our Publications</h1>
                <p class="section-subtitle max-w-2xl mx-auto">A collection of our peer-reviewed research in high-impact journals and international conferences.</p>
            </div>
            
            <PublicationList initialPublications={sortedPublications} client:load />
        </div>
    </main>
    
    <Footer />
</BaseLayout>
