---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PublicationList from '../components/ui/PublicationList.jsx';

const allPublications = await getCollection('publications');
const sortedPublications = allPublications.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Publications" description="Research publications from the BioAI Lab.">
    <Header />

    <main>
        <!-- Hero Section -->
        <section class="hero py-24">
            <div class="max-container text-center">
                <span class="section-eyebrow mb-6 inline-block">Research Output</span>
                <h1 class="text-5xl md:text-6xl font-bold mb-8 tracking-tight">Our <span class="text-primary">Publications</span></h1>
                <p class="text-xl text-text-secondary max-w-3xl mx-auto leading-relaxed">Peer-reviewed research published in high-impact journals and international conferences.</p>
            </div>
        </section>

        <!-- Publications List -->
        <section class="py-20">
            <div class="max-container">
                <PublicationList initialPublications={sortedPublications} client:load />
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>
