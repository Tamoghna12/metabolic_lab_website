---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const teamMembers = await getCollection('team');
const sortedTeam = teamMembers.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));
---

<BaseLayout title="Team" description="Meet the multidisciplinary team of scientists and engineers at the BioAI Lab.">
    <Header />

    <main class="py-12">
        <div class="max-container">
            <!-- Page Header -->
            <div class="section-header mb-10">
                <span class="section-eyebrow">Our People</span>
                <h1 class="text-4xl md:text-5xl font-bold mb-4 tracking-tight">Meet the <span class="text-primary">BioAI Lab</span> Team</h1>
                <p class="text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">A multidisciplinary group of scientists, engineers, and students working at the intersection of metabolic engineering, systems biology, and artificial intelligence.</p>
            </div>

            <!-- Team Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
                {sortedTeam.map((member, index) => (
                    <a href={`${import.meta.env.BASE_URL}/team/${member.id}`} class="team-profile-card card-surface p-8 flex flex-col items-center text-center group reveal" style={`animation-delay: ${index * 100}ms`}>
                        <div class="w-36 h-36 rounded-full overflow-hidden mb-6 ring-4 ring-primary/10 group-hover:ring-primary/30 transition-all duration-500 shadow-lg">
                            {member.data.image ? (
                                <img src={member.data.image} alt={member.data.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                            ) : (
                                <div class="w-full h-full bg-primary-soft flex items-center justify-center text-4xl font-bold text-primary">
                                    {member.data.name.split(' ').map(n => n[0]).join('')}
                                </div>
                            )}
                        </div>
                        <h3 class="text-xl font-bold mb-2 group-hover:text-primary transition-colors">{member.data.name}</h3>
                        <p class="text-accent font-semibold text-sm mb-4">{member.data.role}</p>
                        <p class="text-text-secondary text-sm leading-relaxed mb-4 line-clamp-3">{member.data.bio}</p>
                        <div class="mt-auto pt-4 border-t border-border w-full">
                            <span class="text-primary text-sm font-semibold group-hover:underline">View Full Profile →</span>
                        </div>
                        {member.data.researchFocus && member.data.researchFocus.length > 0 && (
                            <div class="flex flex-wrap gap-1.5 mt-4 justify-center">
                                {member.data.researchFocus.slice(0, 2).map(focus => (
                                    <span class="text-[10px] uppercase tracking-wider font-bold px-2.5 py-1 rounded-full bg-primary/5 text-primary border border-primary/10">
                                        {focus}
                                    </span>
                                ))}
                                {member.data.researchFocus.length > 2 && (
                                    <span class="text-[10px] uppercase tracking-wider font-bold px-2.5 py-1 rounded-full bg-surface-alt text-text-tertiary">
                                        +{member.data.researchFocus.length - 2}
                                    </span>
                                )}
                            </div>
                        )}
                    </a>
                ))}
            </div>

            <!-- Join Us CTA -->
            <section class="card-surface p-12 text-center bg-gradient-to-br from-primary/5 to-accent/5 border-primary/10">
                <div class="text-5xl mb-6">🔬</div>
                <h2 class="text-3xl font-bold mb-4">Join Our Team</h2>
                <p class="text-text-secondary max-w-2xl mx-auto mb-8 leading-relaxed">We're always looking for motivated students and researchers passionate about advancing biological intelligence through computational methods.</p>
                <div class="flex flex-wrap gap-4 justify-center">
                    <a href={`${import.meta.env.BASE_URL}/#contact`} class="pill-button">Contact Us</a>
                    <a href={`${import.meta.env.BASE_URL}/research`} class="pill-button secondary">View Our Research</a>
                </div>
            </section>
        </div>
    </main>

    <Footer />
</BaseLayout>

<style>
    .team-profile-card {
        transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
    }

    .team-profile-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-xl);
    }

    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
