---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const allProjects = await getCollection('projects');
---

<BaseLayout title="Research" description="Our research areas and current projects at the BioAI Lab.">
    <Header />
    
    <main class="py-16">
        <div class="max-container">
            <div class="section-header mb-16">
                <span class="section-eyebrow">Our Work</span>
                <h1 class="text-4xl font-bold mb-6">Research Portfolio</h1>
                <p class="section-subtitle max-w-3xl">We integrate experimental and computational approaches to solve global challenges in biotechnology and medicine. Our research portfolio covers a range of high-impact areas from bioprocess optimization to environmental biotechnology.</p>
            </div>
            
            <div class="projects-detail space-y-24">
                {allProjects.map((project, index) => (
                    <section id={project.id} class={`flex flex-col ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'} gap-12 items-center`}>
                        <div class="project-image flex-1 w-full max-w-xl">
                            <div class="card-surface p-2 rounded-2xl overflow-hidden shadow-xl aspect-video bg-background flex items-center justify-center">
                                {project.data.image ? (
                                    <img src={project.data.image} alt={project.data.title} class="w-full h-full object-cover rounded-xl" />
                                ) : (
                                    <span class="text-4xl font-bold opacity-20">PROJECT</span>
                                )}
                            </div>
                        </div>
                        <div class="project-info flex-1">
                            <span class={`text-sm font-bold uppercase tracking-wider px-3 py-1 rounded-full ${project.data.status === 'Active' ? 'bg-success/10 text-success' : 'bg-gray-100 text-gray-500'}`}>
                                {project.data.status}
                            </span>
                            <h2 class="text-3xl font-bold mt-4 mb-6">{project.data.title}</h2>
                            <div class="prose prose-lg text-gray-600 max-w-none">
                                <p>{project.data.summary}</p>
                            </div>
                            <div class="mt-8 flex gap-4">
                                <a href={`${import.meta.env.BASE_URL}/#contact`} class="pill-button small">Collaborate</a>
                                <a href={`${import.meta.env.BASE_URL}/publications`} class="pill-button small secondary">Related Publications</a>
                            </div>
                        </div>
                    </section>
                ))}
            </div>
            
            <section class="research-areas mt-32 py-16 bg-surface/30 rounded-3xl p-12">
                <h2 class="text-3xl font-bold text-center mb-12">Core Research Domains</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                    <div class="area-card text-center">
                        <div class="text-4xl mb-4">🧬</div>
                        <h3 class="text-xl font-bold mb-4">Metabolic Engineering</h3>
                        <p class="text-gray-600">Genetic optimization of microbial factories for high-yield production of platform chemicals and fuels.</p>
                    </div>
                    <div class="area-card text-center">
                        <div class="text-4xl mb-4">💻</div>
                        <h3 class="text-xl font-bold mb-4">Systems Biology</h3>
                        <p class="text-gray-600">Integrative computational modeling of genome-scale biological networks to predict cellular behavior.</p>
                    </div>
                    <div class="area-card text-center">
                        <div class="text-4xl mb-4">🌿</div>
                        <h3 class="text-xl font-bold mb-4">Bioprocess Control</h3>
                        <p class="text-gray-600">Digital twin development and real-time process monitoring for industrial scale biomanufacturing.</p>
                    </div>
                </div>
            </section>
        </div>
    </main>
    
    <Footer />
</BaseLayout>
